ARG BUILDPLATFORM
ARG TARGETPLATFORM

FROM --platform=$BUILDPLATFORM node:22-alpine AS builder

WORKDIR /app

COPY avmatrix-shared/package.json avmatrix-shared/package-lock.json ./avmatrix-shared/
RUN npm ci --prefix avmatrix-shared

COPY avmatrix-shared ./avmatrix-shared
RUN npm run build --prefix avmatrix-shared

COPY avmatrix-web/package.json avmatrix-web/package-lock.json ./avmatrix-web/
RUN npm ci --prefix avmatrix-web

COPY avmatrix-web ./avmatrix-web
RUN npm run build --prefix avmatrix-web

FROM nginx:alpine AS runtime

RUN apk add --no-cache curl

COPY docker/web-nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/avmatrix-web/dist /usr/share/nginx/html

EXPOSE 4173
